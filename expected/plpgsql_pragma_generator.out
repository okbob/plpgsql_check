-- error cases
create function gtp_err1()
returns void as $$
begin
  create temp table gtp_e1 as select * from gtp_nonexistent;
end;
$$ language plpgsql;
-- generator reports same error like plpgsql_check_function
select * from plpgsql_check_function('gtp_err1()');
